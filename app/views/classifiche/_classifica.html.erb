<% righe = ClassificaQuery.new(classe: classe, materia: materia).righe %>
<% tot_sezioni = righe.sum { |r| r["sezioni"].to_i } %>
<% tot_alunni  = righe.sum { |r| r["alunni"].to_i } %>

<details class="mb-6 border rounded p-4"
         data-materia-codice="<%= materia.codice %>" open>
  <summary class="font-medium text-lg cursor-pointer flex items-center gap-3 flex-wrap">
    <span class="flex-1">
      <%= materia.nome %> <span class="text-gray-500">(<%= materia.codice %>)</span>
    </span>
    <span class="text-sm text-gray-600 whitespace-nowrap">
      <%= number_with_delimiter tot_sezioni %> sez · <%= number_with_delimiter tot_alunni %> al
    </span>
    <button type="button"
            class="text-base px-2 py-1 border rounded hover:bg-gray-200"
            data-action="demote"
            title="OK — clicca per spostare in 'Da controllare'">👍</button>
    <button type="button"
            class="text-base px-2 py-1 border rounded hover:bg-gray-200"
            data-action="promote"
            title="Da controllare — clicca per riportare su" hidden>👎</button>
  </summary>

  <table class="w-full mt-4 text-sm">
    <thead>
      <tr class="text-left border-b">
        <th class="py-1 pr-3">#</th>
        <th class="py-1 pr-3">Titolo</th>
        <th class="py-1 pr-3">ISBN</th>
        <th class="py-1 pr-3">Editore</th>
        <th class="py-1 pr-3 text-right">Sezioni</th>
        <th class="py-1 pr-3 text-right">Alunni</th>
        <th class="py-1 pr-3 text-right">Quota %</th>
      </tr>
    </thead>
    <tbody>
      <% righe.each_with_index do |r, i| %>
        <tr class="border-b">
          <td class="py-1 pr-3"><%= i + 1 %></td>
          <td class="py-1 pr-3"><%= r["titolo"] %></td>
          <td class="py-1 pr-3 font-mono text-xs"><%= r["isbn"] %></td>
          <td class="py-1 pr-3"><%= r["editore"] %></td>
          <td class="py-1 pr-3 text-right"><%= number_with_delimiter r["sezioni"] %></td>
          <td class="py-1 pr-3 text-right"><%= number_with_delimiter r["alunni"] %></td>
          <td class="py-1 pr-3 text-right"><%= number_with_precision r["quota"], precision: 1 %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= render "aggregato_editori", classe: classe, materia: materia %>
</details>
