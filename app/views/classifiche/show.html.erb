<div class="max-w-7xl mx-auto p-6 space-y-6" data-demote-root>
  <header class="flex items-center justify-between flex-wrap gap-3">
    <h1 class="text-3xl font-bold">Classifiche</h1>
    <div class="flex items-center gap-3 text-sm">
      <span class="text-gray-600">
        <%= @ultimo_caricamento.filename %> — <%= l @ultimo_caricamento.caricato_il, format: :short %>
      </span>
      <button type="button"
              class="px-3 py-1 border rounded hover:bg-gray-100"
              data-action="hide-all-demoted">Nascondi "Da controllare"</button>
      <button type="button"
              class="px-3 py-1 border rounded hover:bg-gray-100"
              data-action="reset">Mostra tutto</button>
      <%= link_to "Sostituisci file", new_caricamento_path, class: "underline" %>
    </div>
  </header>

  <nav class="flex gap-1 border-b" role="tablist">
    <% @classifiche.each_with_index do |(classe, _materie), i| %>
      <button type="button"
              role="tab"
              data-action="select-tab"
              data-tab="<%= classe %>"
              aria-selected="<%= i.zero? %>"
              class="px-5 py-2 text-lg font-semibold border-b-2 -mb-px
                     <%= i.zero? ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700' %>">
        Classe <%= classe %>
      </button>
    <% end %>
  </nav>

  <% @classifiche.each_with_index do |(classe, materie), i| %>
    <section role="tabpanel"
             data-classe-section="<%= classe %>"
             <%= "hidden" unless i.zero? %>>
      <div data-zone="primary">
        <% materie.each do |materia| %>
          <%= render "classifica", classe: classe, materia: materia %>
        <% end %>
      </div>

      <div data-divider class="my-6 border-t border-gray-300 pt-4" hidden>
        <h3 class="text-sm uppercase tracking-wide text-gray-500 mb-3">Da controllare</h3>
      </div>

      <div data-zone="demoted" class="bg-gray-100 rounded p-4">
        <%# popolato dinamicamente dal JS %>
      </div>
    </section>
  <% end %>
</div>

<script>
(function () {
  const STORAGE_KEY = "capo:demoted";
  const HIDE_KEY    = "capo:hideDemoted";
  const TAB_KEY     = "capo:activeTab";

  function loadDemoted() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return new Set();
      const arr = JSON.parse(raw);
      return new Set(Array.isArray(arr) ? arr : []);
    } catch (_) { return new Set(); }
  }
  function saveDemoted(set) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify([...set])); } catch (_) {}
  }
  function loadHide() {
    try { return localStorage.getItem(HIDE_KEY) === "true"; } catch (_) { return false; }
  }
  function saveHide(v) {
    try { localStorage.setItem(HIDE_KEY, v ? "true" : "false"); } catch (_) {}
  }
  function loadTab() {
    try { return localStorage.getItem(TAB_KEY); } catch (_) { return null; }
  }
  function saveTab(t) {
    try { localStorage.setItem(TAB_KEY, t); } catch (_) {}
  }

  const root = document.querySelector("[data-demote-root]");
  if (!root) return;

  const demoted = loadDemoted();
  let hideDemoted = loadHide();
  let activeTab = loadTab();

  const sections = [...root.querySelectorAll("[data-classe-section]")];
  const tabs = [...root.querySelectorAll('[data-action="select-tab"]')];
  const validTabs = sections.map(s => s.dataset.classeSection);
  if (!validTabs.includes(activeTab)) activeTab = validTabs[0];

  function applyTab() {
    sections.forEach(s => { s.hidden = s.dataset.classeSection !== activeTab; });
    tabs.forEach(btn => {
      const isActive = btn.dataset.tab === activeTab;
      btn.setAttribute("aria-selected", isActive);
      btn.classList.toggle("border-blue-500", isActive);
      btn.classList.toggle("text-blue-600", isActive);
      btn.classList.toggle("border-transparent", !isActive);
      btn.classList.toggle("text-gray-500", !isActive);
      btn.classList.toggle("hover:text-gray-700", !isActive);
    });
  }

  function applyState() {
    sections.forEach((section) => {
      const classe = section.dataset.classeSection;
      const primary = section.querySelector('[data-zone="primary"]');
      const demotedZone = section.querySelector('[data-zone="demoted"]');
      const divider = section.querySelector("[data-divider]");

      section.querySelectorAll("[data-materia-codice]").forEach((materia) => {
        const codice = materia.dataset.materiaCodice;
        const key = `${classe}:${codice}`;
        const isDemoted = demoted.has(key);
        const target = isDemoted ? demotedZone : primary;
        if (materia.parentNode !== target) target.appendChild(materia);
        const downBtn = materia.querySelector('[data-action="demote"]');
        const upBtn   = materia.querySelector('[data-action="promote"]');
        if (downBtn) downBtn.hidden = isDemoted;
        if (upBtn)   upBtn.hidden   = !isDemoted;
      });

      const hasDemoted = demotedZone.children.length > 0;
      divider.hidden = !hasDemoted || hideDemoted;
      demotedZone.hidden = !hasDemoted || hideDemoted;
    });
  }

  root.addEventListener("click", (e) => {
    const target = e.target.closest("[data-action]");
    if (!target || !root.contains(target)) return;
    const action = target.dataset.action;

    if (action === "demote" || action === "promote") {
      e.preventDefault();
      e.stopPropagation();
      const materia = target.closest("[data-materia-codice]");
      const section = materia.closest("[data-classe-section]");
      const key = `${section.dataset.classeSection}:${materia.dataset.materiaCodice}`;
      if (action === "demote") demoted.add(key); else demoted.delete(key);
      saveDemoted(demoted);
      applyState();
    } else if (action === "hide-all-demoted") {
      hideDemoted = true;
      saveHide(true);
      applyState();
    } else if (action === "reset") {
      demoted.clear();
      saveDemoted(demoted);
      hideDemoted = false;
      saveHide(false);
      applyState();
    } else if (action === "select-tab") {
      activeTab = target.dataset.tab;
      saveTab(activeTab);
      applyTab();
    }
  });

  applyTab();
  applyState();
})();
</script>
