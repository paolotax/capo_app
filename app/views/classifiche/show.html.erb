<% content_for :title, "Classifiche" %>

<div class="min-h-screen bg-stone-50 text-stone-900"
     data-controller="classifiche"
     data-classifiche-storage-key-value="capo:demoted"
     data-classifiche-hide-key-value="capo:hideDemoted"
     data-classifiche-tab-key-value="capo:activeTab">

  <div class="grid grid-cols-1 lg:grid-cols-[248px_1fr]">

    <%# ── SIDEBAR ─────────────────────────────────────────── %>
    <aside class="hidden lg:flex lg:flex-col gap-6 sticky top-0 h-screen px-5 py-6
                  bg-stone-100/70 border-r border-stone-200">
      <div>
        <div class="flex items-baseline gap-2 px-1">
          <span class="font-serif italic text-3xl leading-none text-orange-700">✺</span>
          <span class="font-serif text-xl tracking-tight">Capò</span>
        </div>
        <div class="mt-1 px-1 text-[11px] uppercase tracking-[0.14em] text-stone-500">
          Classifiche adozioni
        </div>
      </div>

      <div>
        <div class="px-1 pb-2 mb-1 text-[11px] uppercase tracking-[0.14em] text-stone-500
                    border-b border-stone-200">Classi</div>
        <nav class="flex flex-col gap-0.5">
          <% @classifiche.each_with_index do |(classe, materie), i| %>
            <button type="button"
                    role="tab"
                    data-action="click->classifiche#selectTab"
                    data-classifiche-target="tab"
                    data-tab="<%= classe %>"
                    aria-selected="<%= i.zero? %>"
                    class="grid grid-cols-[28px_1fr_auto] items-center gap-2 px-2.5 py-2
                           rounded-md text-left text-stone-700 hover:bg-stone-200/60 transition
                           aria-selected:bg-stone-900 aria-selected:text-stone-50">
              <span class="font-serif italic text-xl leading-none text-orange-700
                           text-center group-aria-selected:text-stone-50"><%= %w[I II III IV V][classe-1] %></span>
              <span class="text-sm">Classe <%= classe %></span>
              <span class="text-[11px] tabular-nums text-stone-400"
                    data-classifiche-target="tabCount"
                    data-tab-count="<%= classe %>"><%= materie.size %></span>
            </button>
          <% end %>
        </nav>
      </div>

      <div class="mt-auto rounded-lg border border-stone-200 bg-white p-3 text-xs text-stone-500">
        <span class="block font-mono text-[11px] text-stone-700 break-all mb-1">
          <%= @ultimo_caricamento.filename %>
        </span>
        <span class="block mb-2">Caricato <%= l @ultimo_caricamento.caricato_il, format: :short %></span>
        <%= link_to "Sostituisci file →", new_caricamento_path,
              class: "text-orange-700 border-b border-orange-700/60 hover:border-orange-700" %>
      </div>
    </aside>

    <%# ── MAIN ───────────────────────────────────────────── %>
    <main class="px-6 lg:px-12 py-8 pb-24 max-w-[1400px]">

      <header class="flex flex-wrap items-end justify-between gap-6 pb-5 mb-7
                     border-b border-stone-200">
        <h1 class="font-serif font-normal text-5xl lg:text-6xl leading-[0.95] tracking-tight m-0">
          Classifiche
          <em data-classifiche-target="classeRoman" class="italic text-orange-700 not-italic-fix">I</em>
        </h1>
        <div class="text-xs text-stone-500 text-right">
          <div>
            <span data-classifiche-target="materieCount" class="font-medium text-stone-700">—</span> materie ·
            <span data-classifiche-target="titoliCount"  class="font-medium text-stone-700">—</span> titoli
          </div>
          <div>Aggiornate <%= l @ultimo_caricamento.caricato_il, format: :short %></div>
        </div>
      </header>

      <%# Tab inline (mobile fallback per la sidebar) %>
      <nav class="lg:hidden flex gap-1 p-1 mb-6 bg-stone-100 rounded-lg w-fit" role="tablist">
        <% @classifiche.each_with_index do |(classe, _), i| %>
          <button type="button"
                  role="tab"
                  data-action="click->classifiche#selectTab"
                  data-classifiche-target="tabMobile"
                  data-tab="<%= classe %>"
                  aria-selected="<%= i.zero? %>"
                  class="px-4 py-2 rounded-md text-sm text-stone-500
                         aria-selected:bg-white aria-selected:text-stone-900 aria-selected:shadow-sm">
            <span class="font-serif italic text-orange-700"><%= %w[I II III IV V][classe-1] %></span>
            <span class="ml-1">Classe</span>
          </button>
        <% end %>
      </nav>

      <%# Toolbar %>
      <div class="flex flex-wrap items-center gap-2.5 mb-6">
        <div class="relative flex-1 min-w-[280px]">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" width="14" height="14"
               viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="7" cy="7" r="4.5"/><path d="M10.5 10.5 L14 14" stroke-linecap="round"/>
          </svg>
          <input type="text"
                 placeholder="Cerca titolo, autore o ISBN…"
                 data-classifiche-target="search"
                 data-action="input->classifiche#filter"
                 class="w-full bg-stone-100 border border-stone-200 rounded-md pl-9 pr-3 py-2
                        text-sm focus:outline-none focus:border-stone-400 focus:bg-white">
        </div>
        <select data-classifiche-target="editoreFilter"
                data-action="change->classifiche#filter"
                class="bg-stone-100 border border-stone-200 rounded-md px-3 py-2 text-sm text-stone-700">
          <option value="all">Tutti gli editori</option>
          <% @classifiche.values.flatten.flat_map(&:righe_capo).map(&:editore).compact.uniq.sort.each do |e| %>
            <option value="<%= e %>"><%= e %></option>
          <% end %>
        </select>
        <button type="button"
                data-action="click->classifiche#toggleDemoted"
                data-classifiche-target="toggleHide"
                class="px-3 py-2 text-sm rounded-md border border-dashed border-stone-300
                       text-stone-500 hover:bg-stone-100">Nascondi 👎</button>
      </div>

      <%# Pannelli per ogni classe %>
      <% @classifiche.each_with_index do |(classe, materie), i| %>
        <section role="tabpanel"
                 data-classifiche-target="panel"
                 data-classe-section="<%= classe %>"
                 data-classe="<%= classe %>"
                 data-roman="<%= %w[I II III IV V][classe-1] %>"
                 data-materie-count="<%= materie.size %>"
                 <%= "hidden" unless i.zero? %>>

          <div data-zone="primary">
            <% materie.each do |materia| %>
              <%= render "classifica", classe: classe, materia: materia %>
            <% end %>
          </div>

          <div data-divider class="mt-9 pt-5 border-t border-dashed border-stone-300" hidden>
            <h3 class="font-serif italic text-lg text-stone-500 m-0 mb-3">Da controllare</h3>
          </div>

          <div data-zone="demoted" class="space-y-0"></div>
        </section>
      <% end %>
    </main>
  </div>
</div>
