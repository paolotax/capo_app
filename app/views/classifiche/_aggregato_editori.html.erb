<% editori = ClassificaEditoreQuery.new(classe: classe, materia: materia).righe %>
<% if editori.any? %>
  <div class="mt-6 pt-5 border-t border-stone-200">
    <div class="flex items-baseline justify-between mb-3">
      <h4 class="font-serif italic text-lg text-stone-700 m-0 font-normal">Aggregato per editore</h4>
      <span class="text-[11px] uppercase tracking-[0.12em] text-stone-400"><%= editori.size %> editori</span>
    </div>
    <table class="w-full text-xs tabular-nums">
      <thead>
        <tr class="text-left">
          <th class="py-2 pr-3 text-[10px] uppercase tracking-[0.12em] text-stone-500 font-medium border-b border-stone-200">Editore</th>
          <th class="py-2 pr-3 text-[10px] uppercase tracking-[0.12em] text-stone-500 font-medium border-b border-stone-200 text-right">Titoli</th>
          <th class="py-2 pr-3 text-[10px] uppercase tracking-[0.12em] text-stone-500 font-medium border-b border-stone-200 text-right">Sezioni</th>
          <th class="py-2 pr-3 text-[10px] uppercase tracking-[0.12em] text-stone-500 font-medium border-b border-stone-200 text-right">Alunni</th>
          <th class="py-2 pr-3 text-[10px] uppercase tracking-[0.12em] text-stone-500 font-medium border-b border-stone-200 text-right w-[160px]">Quota</th>
        </tr>
      </thead>
      <tbody>
        <% editori.each_with_index do |r, i| %>
          <tr class="border-b border-stone-100 last:border-0">
            <td class="py-1.5 pr-3 text-stone-800"><%= r["editore"] %></td>
            <td class="py-1.5 pr-3 text-right"><%= r["titoli"] %></td>
            <td class="py-1.5 pr-3 text-right"><%= number_with_delimiter r["sezioni"] %></td>
            <td class="py-1.5 pr-3 text-right text-stone-500"><%= number_with_delimiter r["alunni"] %></td>
            <td class="py-1.5 pr-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <div class="w-[70px] h-1 bg-stone-200 rounded overflow-hidden">
                  <div class="h-full <%= i.zero? ? 'bg-orange-700' : 'bg-stone-400/60' %>"
                       style="width: <%= [r["quota"], 100].min %>%"></div>
                </div>
                <span class="text-stone-700 min-w-[40px] text-right">
                  <%= number_with_precision r["quota"], precision: 1 %>%
                </span>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
